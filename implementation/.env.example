# VLM provider — ollama is the dev default; claude is provisioned only (ADR-0002).
VLM_PROVIDER=ollama

# Host Ollama. v2 default is qwen3-vl:235b-cloud (Ollama Cloud, ~20× the
# parameter count of llama3.2-vision; better spatial bbox extraction
# without prompt gymnastics — see SOLUTION-DESIGN-V2 §10 + docs/vlm-setup.md).
# Setup: `ollama signin` then `ollama pull qwen3-vl:235b-cloud` on the host.
# Override to `llama3.2-vision` to run fully local without cloud auth.
OLLAMA_HOST_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3-vl:235b-cloud

# Anthropic — leave blank for v1.
ANTHROPIC_API_KEY=
