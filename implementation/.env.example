# VLM provider — ollama is the dev default; claude is provisioned only (ADR-0002).
VLM_PROVIDER=ollama

# Host Ollama (run `ollama serve` + `ollama pull llama3.2-vision` on the host).
OLLAMA_HOST_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2-vision

# Anthropic — leave blank for v1.
ANTHROPIC_API_KEY=
